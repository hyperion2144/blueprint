-{{approach}}
+**`src/core/move.ts`** — direction arithmetic + tile lookup:
+```ts
+const DELTAS: Record<Direction, Coord> = {
+  N: { x: 0, y: -1 },
+  S: { x: 0, y:  1 },
+  E: { x:  1, y: 0 },
+  W: { x: -1, y: 0 },
+};
+
+export function attemptMove(state: GameState, dir: Direction): MoveResult | null {
+  const delta = DELTAS[dir];
+  const target: Coord = { x: state.player.x + delta.x, y: state.player.y + delta.y };
+  const beyond: Coord = { x: target.x + delta.x, y: target.y + delta.y };
+
+  // Wall at target → can't move
+  if (state.static.walls.has(target)) return null;
+
+  // Box at target?
+  const boxIdx = state.boxes.findIndex((b) => b.x === target.x && b.y === target.y);
+  if (boxIdx === -1) {
+    // No box → walk
+    return { player: target, boxes: null, pushedIndex: undefined, boxFrom: undefined };
+  }
+
+  // Box at target. Can we push it?
+  if (state.static.walls.has(beyond)) return null;
+  const blockerIdx = state.boxes.findIndex((b) => b.x === beyond.x && b.y === beyond.y);
+  if (blockerIdx !== -1) return null;
+
+  const boxFrom = state.boxes[boxIdx];
+  if (!boxFrom) return null; // satisfies noUncheckedIndexedAccess
+  const newBoxes = state.boxes.slice();
+  newBoxes[boxIdx] = beyond;
+  return { player: target, boxes: newBoxes, pushedIndex: boxIdx, boxFrom };
+}
+```
+
+**`src/core/history.ts`** — entry push/pop/clear:
+```ts
+export function pushEntry(state: GameState, entry: HistoryEntry): GameState {
+  return { ...state, history: [...state.history, entry] };
+}
+
+export function popEntry(state: GameState): { state: GameState; entry: HistoryEntry } | null {
+  if (state.history.length === 0) return null;
+  const entry = state.history[state.history.length - 1];
+  if (!entry) return null;
+  return { state: { ...state, history: state.history.slice(0, -1) }, entry };
+}
+
+export function clearHistory(state: GameState): GameState {
+  return { ...state, history: [] };
+}
+```
+
+**Tests** — pure logic, node env, per-test inline `Level` fixtures using `createInitialState` from c1.
 
