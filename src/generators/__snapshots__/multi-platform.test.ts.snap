  ".omp/agents/bp-reviewer.md": "---
name: bp-reviewer
description: Triple review — spec review + quality review + goal review
tools:
  - read
  - grep
  - glob
  - lsp
  - ast_grep
  - bash
model: pi/default
thinkingLevel: xhigh
spawns: "*"
blocking: false
