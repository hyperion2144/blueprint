{
  "name": "@hyperion2144/blueprint",
  "version": "0.5.0",
  "description": "Blueprint \u2014 spec-driven development workflow for AI coding agents",
  "type": "module",
  "bin": {
    "bp": "bin/cli.js"
  },
  "scripts": {
    "build:grammar": "node scripts/prepare.mjs",
    "build": "node scripts/prepare.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "node scripts/prepare.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^15.0.0",
    "gray-matter": "^4.0.3",
    "peggy": "^5.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "spec-driven",
    "workflow",
    "ai-agent",
    "cli",
    "openspec",
    "gsd"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperion2144/blueprint.git"
  },
  "exports": {
    ".": "./dist/cli.js"
  }
